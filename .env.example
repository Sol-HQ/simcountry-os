# Environment Variables — SimCountry OS

# ─────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # server-side only

# ─────────────────────────────────────────
# Solana
# ─────────────────────────────────────────
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta   # mainnet-beta | devnet | testnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
NEXT_PUBLIC_NATION_NAME=SimCountry OS
NEXT_PUBLIC_APP_URL=http://localhost:3000
